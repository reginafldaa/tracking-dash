generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  }

model User {
  id           String        @id @default(cuid())
  name         String?
  email        String        @unique
  password     String
  phone        String?
  role         Role          @default(USER)
  image        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  pendaftarans Pendaftaran[]
}

model Pelatihan {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  image       String?
  status      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jadwals     Jadwal[]
  pendaftarans Pendaftaran[]
}

model Jadwal {
  id           String        @id @default(cuid())
  date         DateTime
  location     String?
  pelatihanId  String
  status       String 
  metode       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  pelatihan    Pelatihan     @relation(fields: [pelatihanId], references: [id], onDelete: Cascade)
  pendaftarans Pendaftaran[]
}

enum MetodePendaftaran {
  ONLINE
  OFFLINE
}

enum StatusPendaftaran {
  MENUNGGU
  PROSES
  LULUS
  GAGAL
}

model Pendaftaran {
  id             String              @id @default(cuid())
  namaLengkap    String
  email          String
  noTelp         String
  pekerjaan      String
  instansi       String
  metode         MetodePendaftaran
  pelatihanId    String
  fotoKtp        String
  ijazah         String
  pasFoto        String
  suratKerja     String?
  buktiTransfer  String
  status         StatusPendaftaran   @default(MENUNGGU)
  userId         String
  jadwalId       String
  documentUrl    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  pelatihan      Pelatihan           @relation(fields: [pelatihanId], references: [id], onDelete: Cascade)
  jadwal         Jadwal             @relation(fields: [jadwalId], references: [id], onDelete: Cascade)
  user           User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  absensis       Absensi[]
  sertifikats    Sertifikat[]
}

model Absensi {
  id            String      @id @default(cuid())
  pendaftaranId String
  checkIn       DateTime?
  checkOut      DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  pendaftaran   Pendaftaran @relation(fields: [pendaftaranId], references: [id], onDelete: Cascade)
}

model Sertifikat {
  id             String      @id @default(cuid())
  pendaftaranId  String
  certificateUrl String
  issuedAt       DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  pendaftaran    Pendaftaran @relation(fields: [pendaftaranId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}
